# ─────────────────────────────────────────────────────────
# Snout OS — Environment Variables
# Copy to .env and fill in values before running.
# ─────────────────────────────────────────────────────────

# ── AUTH ────────────────────────────────────────────────
# NextAuth v5 configuration
NEXTAUTH_URL="http://localhost:3000"                      # Full public URL of the app
NEXTAUTH_SECRET=""                                        # Generate: openssl rand -base64 32

# Auth enforcement (defaults to true in production)
ENABLE_AUTH_PROTECTION=true                               # Middleware enforces auth on protected routes
ENABLE_SITTER_AUTH=true                                   # Sitter role enforcement on /sitter/* routes
ENABLE_PERMISSION_CHECKS=true                             # Permission-level checks (RBAC)

# E2E testing auth (NEVER enable in production)
ENABLE_E2E_AUTH=false                                     # Allows E2E test login endpoint
E2E_AUTH_KEY="test-e2e-key-change-in-production"          # Key for E2E login — change this

# ── DATABASE ──────────────────────────────��─────────────
DATABASE_URL="postgresql://user:password@localhost:5432/snout_os_db"  # PostgreSQL connection string

# ── REDIS / QUEUES ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"                        # Required for BullMQ workers, SSE, rate limiting

# ── STRIPE ──────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."                           # Stripe secret key
STRIPE_PUBLISHABLE_KEY="pk_test_..."                      # Stripe publishable key (client-side)
STRIPE_WEBHOOK_SECRET="whsec_..."                         # Webhook signing secret (from Stripe dashboard → Webhooks)

# Stripe Connect (sitter payouts)
# Payouts require sitters to onboard via POST /api/sitter/stripe/connect
STRIPE_MOCK_TRANSFER=false                                # Set true in dev to skip real transfers

# ���─ TWILIO ──────────────────────────────────────────────
# Dashboard: https://console.twilio.com
TWILIO_ACCOUNT_SID="AC..."                                # Account SID
TWILIO_AUTH_TOKEN=""                                       # Auth token
TWILIO_PHONE_NUMBER="+1234567890"                         # Primary business Twilio number
TWILIO_WEBHOOK_AUTH_TOKEN=""                               # Optional webhook signature validation token
ENABLE_WEBHOOK_VALIDATION=false                           # Verify Twilio webhook signatures

# ── OPENPHONE ───────────────────────────────────────────
# Dashboard: https://app.openphone.com/settings/api
OPENPHONE_API_KEY=""                                       # API key from OpenPhone settings
OPENPHONE_PHONE_NUMBER="+1234567890"                      # OpenPhone business number (E.164 format)
OPENPHONE_NUMBER_ID=""                                     # OpenPhone number ID (not the phone number)
OPENPHONE_WEBHOOK_SECRET=""                                # Webhook signature secret

# ── MESSAGING ───────────────────────────────────────────
MESSAGING_PROVIDER="none"                                  # "none" | "twilio" | "openphone"
ENFORCE_MASKED_ONLY_MESSAGING=false                       # Force all messaging through masked numbers (true in prod)
NEXT_PUBLIC_ENABLE_MESSAGING_V1=true                      # Enable new messaging inbox UI
ENABLE_SITTER_MESSAGES_V1=false                           # Enable sitter messaging features
ENABLE_PROACTIVE_THREAD_CREATION=false                    # Auto-create threads for new bookings

# ── OWNER PHONE NUMBERS ────────────────────────────────
OWNER_PHONE="+1234567890"                                  # Fallback owner phone
OWNER_PERSONAL_PHONE="+1234567890"                        # Owner personal cell (receives new booking SMS)
OWNER_OPENPHONE_PHONE="+1234567890"                       # Owner's OpenPhone number (if using OpenPhone)
OWNER_PHONE_TYPE="personal"                                # Default phone type: "personal" | "openphone"

# ── GOOGLE CALENDAR ─────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""                                        # OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=""                                    # OAuth 2.0 client secret
ENABLE_GOOGLE_BIDIRECTIONAL_SYNC=false                    # Two-way Google Calendar sync
NEXT_PUBLIC_ENABLE_GOOGLE_BIDIRECTIONAL_SYNC=false
NEXT_PUBLIC_ENABLE_CALENDAR_V1=false                      # Calendar UI feature flag

# ── AWS S3 (File Storage) ──────────────────────────────
# Console: https://console.aws.amazon.com/s3
S3_BUCKET=""                                               # S3 bucket name
S3_REGION="us-east-1"                                      # AWS region
S3_ACCESS_KEY_ID=""                                        # IAM access key
S3_SECRET_ACCESS_KEY=""                                    # IAM secret key

# ── EMAIL (Resend) ─────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=""                                          # Resend API key for transactional email
EMAIL_FROM="Snout Pet Care <noreply@snoutservices.com>"   # From address for emails

# ── AI / OPENAI ─────────────────────────────────────────
OPENAI_API_KEY=""                                          # OpenAI API key for AI features (daily delight, sitter matching)
ENABLE_RESONANCE_V1=false                                  # AI suggestions layer
NEXT_PUBLIC_ENABLE_RESONANCE_V1=false

# ── PUSH NOTIFICATIONS ─────────────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""                            # VAPID public key (client-side)
VAPID_PRIVATE_KEY=""                                       # VAPID private key (server-side)

# ── SENTRY (Error Tracking) ──────────────��─────────────
# Dashboard: https://sentry.io/settings/projects/
SENTRY_DSN=""                                              # Sentry DSN for server-side
NEXT_PUBLIC_SENTRY_DSN=""                                  # Sentry DSN for client-side
SENTRY_AUTH_TOKEN=""                                       # Sentry auth token for source maps

# ── APP URLS ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"                # Public URL of the app (used in emails, SMS links)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"               # Base URL fallback
NEXT_PUBLIC_API_URL="http://localhost:3001"                # NestJS API (if using BFF proxy)

# ── PERSONAL MODE ───────────────────────────────────────
# Single-org deployment for Carson's Snout business
NEXT_PUBLIC_PERSONAL_MODE=true                             # Lock all requests to PERSONAL_ORG_ID
PERSONAL_ORG_ID="default"                                  # Org ID for personal mode
PERSONAL_BRAND_NAME="Snout Pet Care"                      # Brand name shown in UI
PERSONAL_PRIMARY_COLOR="#432f21"                           # Brand primary color

# ── FEATURE FLAGS ───────────────────────────────────────
ENABLE_FORM_MAPPER_V1=false                               # New booking form field mapper
USE_PRICING_ENGINE_V1=false                               # Pricing engine V1
ENABLE_OPS_SRS=false                                      # SRS system operations

# ── INTERNAL / CRON ─────────────────────────────────────
INTERNAL_API_KEY=""                                         # Auth key for cron endpoints (Bearer token)
# Used by: /api/cron/expire-unpaid, /api/cron/collect-balances, /api/cron/weekly-recurring-charge
# Also: /api/messages/process-srs, /api/offers/expire

# ── RUNTIME ─────────────────────────────────────────────
RUNTIME_ENV_NAME="development"                             # "development" | "staging" | "production"
NEXT_PUBLIC_GIT_SHA=""                                     # Git commit SHA (auto-set by Render)
NEXT_PUBLIC_BUILD_TIME=""                                   # Build timestamp

# ── AUTOMATION QUEUE ────────────────────────────────────
AUTOMATION_HIGH_PRIORITY_TYPES="bookingConfirmation,ownerNewBookingAlert"  # Comma-separated list
AUTH_TRAFFIC_LIMIT_PER_MINUTE=1800                        # Rate limit for authenticated API traffic
