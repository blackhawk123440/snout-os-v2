// AI Governance
model OrgAISettings {
  id                 String   @id @default(uuid())
  orgId              String   @unique
  enabled            Boolean  @default(true)
  monthlyBudgetCents Int      @default(0) // 0 = unlimited (see docs/AI_GOVERNANCE.md)
  hardStop           Boolean  @default(false)
  allowedModels      Json? // optional array of model names
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([orgId])
}

model AIPromptTemplate {
  id        String   @id @default(uuid())
  orgId     String? // null = global template
  key       String // e.g. daily_delight, sitter_match, pricing_suggestion
  version   Int      @default(1)
  template  String   @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([orgId, key])
  @@index([key])
}

model AIUsageLog {
  id            String   @id @default(uuid())
  orgId         String
  userId        String?
  featureKey    String
  model         String
  promptKey     String   @default("")
  promptVersion Int      @default(0)
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  costCents     Int      @default(0)
  status        String   @default("succeeded") // succeeded | failed | blocked
  error         String?  @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, featureKey, createdAt])
  @@index([featureKey])
}

// ============================================
// LEDGER & RECONCILIATION
// ============================================

model LedgerEntry {
  id          String   @id @default(cuid())
  orgId       String
  entryType   String // charge | refund | payout | fee | adjustment
  source      String // stripe | internal
  stripeId    String?  @unique // payment_intent/charge/refund/transfer id; unique when present
  bookingId   String?
  clientId    String?
  sitterId    String?
  amountCents Int // positive; refunds use entryType=refund
  currency    String   @default("usd")
  status      String   @default("succeeded") // succeeded | failed | pending
  occurredAt  DateTime // timestamp from provider
  createdAt   DateTime @default(now())

  @@index([orgId, occurredAt])
  @@index([orgId, entryType, occurredAt])
}

model ReconciliationRun {
  id           String   @id @default(cuid())
  orgId        String
  rangeStart   DateTime
  rangeEnd     DateTime
  status       String   @default("succeeded") // succeeded | failed
  totalsJson   Json? // sums by type
  mismatchJson Json? // missingInDb, missingInStripe, amountDiffs
  createdAt    DateTime @default(now())

  @@index([orgId])
  @@index([orgId, createdAt])
}

model BookingRequestIdempotency {
  id                 String   @id @default(uuid())
  orgId              String?
  route              String
  idempotencyKey     String
  requestFingerprint String
  reservationStatus  String   @default("reserved") // reserved | completed | failed
  statusCode         Int?
  responseBodyJson   String?  @db.Text
  resourceType       String?
  resourceId         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([orgId, route, idempotencyKey], name: "org_route_idempotency")
  @@index([orgId, route])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// ============================================
// APP ERROR LOG (signup/bootstrap, integration failures)
// ============================================

model AppErrorLog {
  id        String   @id @default(uuid())
  code      String // e.g. "signup.bootstrap_failed", "oauth.callback_mismatch"
  message   String   @db.Text
  context   String?  @db.Text // JSON
  createdAt DateTime @default(now())

  @@index([code])
  @@index([createdAt])
}

// ============================================
// ORG INTEGRATION CONFIG (Settings → Integrations stack)
// ============================================

model OrgIntegrationConfig {
  id                    String   @id @default(uuid())
  orgId                 String   @unique

  /// Messaging: "none" | "twilio" | "openphone"
  messagingProvider     String   @default("none")
  messagingConfigured   Boolean  @default(false)
  messagingFallbackPhone String?

  /// Payments: "stripe" | "square" | "none"
  paymentProvider       String   @default("stripe")
  paymentConfigured     Boolean  @default(false)

  /// Calendar: "none" | "google"
  calendarProvider      String   @default("none")
  calendarConfigured    Boolean  @default(false)

  /// Accounting: "none" | "quickbooks" | "xero"
  accountingProvider    String   @default("none")
  accountingConfigured  Boolean  @default(false)

  /// Booking Intake: "embedded_form" | "client_portal" | "both"
  bookingIntake         String   @default("embedded_form")

  /// Provider-specific config (JSON extensibility)
  providerMeta          String?  @db.Text

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orgId])
}

// Signup idempotency: one row per email to prevent duplicate org/user creation
model SignupIdempotency {
  id             String   @id @default(uuid())
  email          String   @unique
  userId         String?
  orgId          String?
  idempotencyKey String? // optional client-provided key for replay
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model StripeWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())

  @@index([stripeEventId])
}

model DailyOrgStats {
  id                  String   @id @default(cuid())
  orgId               String
  date                DateTime
  bookingsCreated     Int      @default(0)
  bookingsConfirmed   Int      @default(0)
  bookingsCompleted   Int      @default(0)
  revenueTotal        Float    @default(0)
  newClients          Int      @default(0)
  notificationsSent   Int      @default(0)
  createdAt           DateTime @default(now())

  @@unique([orgId, date])
  @@index([orgId, date])
}

model VisitCard {
  id              String    @id @default(cuid())
  orgId           String
  bookingId       String    @unique
  clientId        String
  sitterId        String

  checkInAt       DateTime
  checkOutAt      DateTime
  durationMinutes Int

  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?

  photoUrls       String?   @db.Text
  petChecklists   String?   @db.Text
  sitterNote      String?   @db.Text

  assembledAt     DateTime  @default(now())
  sentToClient    Boolean   @default(false)
  sentAt          DateTime?

  @@index([orgId, clientId])
  @@index([bookingId])
}

model SitterQuietHours {
  id        String   @id @default(cuid())
  orgId     String
  sitterId  String   @unique
  startTime String   // "22:00" in sitter's timezone
  endTime   String   // "07:00" in sitter's timezone
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sitter Sitter @relation(fields: [sitterId], references: [id], onDelete: Cascade)

  @@index([orgId, sitterId])
}

model SitterMileageLog {
  id           String   @id @default(cuid())
  orgId        String
  sitterId     String
  bookingId    String   @unique
  month        String   // "2026-03" for grouping
  estimatedMi  Float
  actualMi     Float?
  fromAddress  String?
  toAddress    String?
  createdAt    DateTime @default(now())

  sitter Sitter @relation(fields: [sitterId], references: [id], onDelete: Cascade)

  @@index([orgId, sitterId, month])
}

model EmergencyVetAuth {
  id                     String   @id @default(cuid())
  orgId                  String
  petId                  String   @unique
  clientId               String
  authorizedUpToCents    Int
  vetName                String?
  vetPhone               String?
  vetAddress             String?
  additionalInstructions String?  @db.Text
  signedAt               DateTime
  signatureName          String
  expiresAt              DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([orgId, clientId])
  @@index([petId])
}
