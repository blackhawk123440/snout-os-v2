{
  "name": "snout-os",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "next dev",
    "worker": "tsx src/worker/index.ts",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 prisma generate && cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "build:with-db": "prisma generate && prisma db push --skip-generate && next build",
    "start": "prisma migrate deploy && node scripts/verify-schema.js && next start",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:core": "vitest run --exclude '**/srs-engine.test.ts' --exclude '**/pool-capacity.test.ts' --exclude '**/one-thread-per-client.test.ts' --exclude '**/twilio-provider.test.ts' --exclude '**/multi-provider-e2e.test.ts' --exclude '**/send.test.ts' --exclude '**/soft-delete.test.ts' --exclude '**/automation-utils-persistence.test.ts' --exclude '**/auth/signup/__tests__/**'",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run --config vitest.config.ts",
    "test:ui": "playwright test",
    "test:ui:smoke": "tsx scripts/smoke.ts",
    "e2e:smoke": "playwright test --config=playwright.smoke.config.ts tests/e2e/smoke.spec.ts tests/e2e/smoke-closed-loop.spec.ts tests/e2e/smoke-ops.spec.ts",
    "test:e2e:a11y": "tsx scripts/smoke.ts --a11y",
    "test:ui:visual": "playwright test",
    "test:ui:owner-snapshots": "playwright test tests/e2e/owner-snapshots.spec.ts --project=owner-desktop",
    "test:ui:full": "playwright test",
    "lighthouse:ci": "lhci autorun",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:smoke:up": "docker compose -f docker-compose.smoke.yml up -d",
    "db:smoke:down": "docker compose -f docker-compose.smoke.yml down",
    "db:smoke:reset": "tsx scripts/db-smoke-reset.ts",
    "test:ui:smoke:local": "tsx scripts/smoke-local.ts",
    "postinstall": "prisma generate",
    "feature:audit": "tsx scripts/feature-audit.ts",
    "check:no-raw-prisma": "tsx scripts/check-no-raw-prisma.ts",
    "check:no-raw-ui": "tsx scripts/check-no-raw-ui.ts",
    "check-env": "tsx scripts/check-env.ts",
    "check:contrast": "tsx scripts/a11y/check-contrast.ts",
    "verify:messaging": "tsx scripts/verify-messaging.ts",
    "verify:payroll": "tsx scripts/verify-payroll.ts",
    "verify:calendar": "tsx scripts/verify-calendar.ts",
    "scenario-test": "tsx scripts/run-real-world-scenarios.ts",
    "load:smoke": "tsx scripts/load/run-gates.ts --suite smoke",
    "load:bookings": "tsx scripts/load/run-gates.ts --suite bookings",
    "load:messages": "tsx scripts/load/run-gates.ts --suite messages",
    "load:reads": "tsx scripts/load/run-gates.ts --suite reads",
    "load:queues": "tsx scripts/load/run-gates.ts --suite queues",
    "load:full": "tsx scripts/load/run-gates.ts --suite full",
    "load:live:ramp": "tsx scripts/load/run-gates.ts --suite live-ramp",
    "load:explain:plans": "tsx scripts/load/explain-query-plans.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1016.0",
    "@date-fns/tz": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@panva/hkdf": "^1.2.1",
    "@prisma/client": "^5.0.0",
    "@sentry/nextjs": "^10.41.0",
    "@sentry/node": "^10.41.0",
    "@serwist/next": "^9.5.6",
    "@tanstack/react-query": "^5.90.20",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^4.0.0",
    "chart.js": "^4.5.1",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.0.0",
    "framer-motion": "^12.34.3",
    "googleapis": "^128.0.0",
    "idb": "^8.0.3",
    "ioredis": "^5.0.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.24.0",
    "postcss": "^8.0.0",
    "prisma": "^5.0.0",
    "react": "^18.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.0.0",
    "serwist": "^9.5.6",
    "stripe": "^14.0.0",
    "tailwindcss": "^3.0.0",
    "twilio": "^5.11.2",
    "typescript": "^5.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.12.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.51.1",
    "@types/node": "^20.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/ui": "^4.0.16",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.5.12",
    "fast-check": "^4.5.3",
    "jsdom": "^28.1.0",
    "tsx": "^4.20.6",
    "vitest": "^4.0.16"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
