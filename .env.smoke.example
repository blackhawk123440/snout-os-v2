# Smoke test environment - copy to .env.smoke and run: pnpm test:ui:smoke:local
# Uses docker-compose.smoke.yml Postgres on port 5433 (avoids conflicts with dev 5432)

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/snout_smoke
PORT=3000
NEXTAUTH_SECRET=test_secret_for_smoke_minimum_32_chars_required
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=test_jwt_secret_for_smoke

# E2E auth (required for Playwright global-setup)
ENABLE_E2E_LOGIN=true
E2E_AUTH_KEY=test-e2e-key-change-in-production

# Smoke mode - relaxes Stripe/S3 checks in verify-runtime
SMOKE=true

# Optional: dummy values if your .env loads Stripe (smoke mode skips strict check)
# STRIPE_SECRET_KEY=sk_test_dummy
# STRIPE_WEBHOOK_SECRET=whsec_dummy

# Messaging
ENABLE_MESSAGING_V1=true
NEXT_PUBLIC_ENABLE_MESSAGING_V1=true
OPENPHONE_API_KEY=test_key
OPENPHONE_NUMBER_ID=test_number_id

# Ops seed for E2E data
ENABLE_OPS_SEED=true
